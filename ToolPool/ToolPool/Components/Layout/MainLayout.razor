@inherits LayoutComponentBase
@using ToolPool.Services
@inject CartService Cart

<div class="shell">
    <header class="topbar">
        <a href="/" class="brand">Tool Pool</a>

        <a class="page" href="/stripe">Stripe</a>
       
        <a class="page" href="/map">Map</a>

        <a href="/cart" class="cart-btn">
            Cart <span class="cart-badge">@Cart.Count</span>
        </a>

    </header>

    <main>@Body</main>
</div>

@code {
    protected override void OnInitialized()
    {
        Cart.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        Cart.OnChange -= StateHasChanged;
    }
}
