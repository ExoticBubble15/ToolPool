@page "/latest-submissions"
@using ToolPool.Models
@using ToolPool.Services
@inject SupabaseDemoService ItemService

<div class="page-wrap">
    <div class="page-hero">
        <h1>Latest Submissions</h1>
        <p>Recent tool suggestions from Supabase.</p>
    </div>

    @if (!Submissions.Any())
    {
        <div class="empty-cart">
            <p>No submissions yet.</p>
            <a href="/stripe" class="btn-back">← Back to Tool Pool</a>
        </div>
    }
    else
    {
        <div class="item-grid">
            @foreach (var s in Submissions)
            {
                <div class="item-card">
                    <div class="item-info">
                        <h3>@s.Name</h3>
                        <p>@s.Description</p>
                        <p>@s.SubmittedAt.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</p>
                    </div>
                    <div class="item-footer">
                        <span class="item-price">$@s.Price.ToString("F2")</span>
                    </div>
                </div>
            }
        </div>

        <div style="margin-top: 1rem;">
            <a href="/stripe" class="btn-back">← Back to Tool Pool</a>
        </div>
    }
</div>

@code {
    private List<ToolSubmission> Submissions = new();

    protected override async Task OnInitializedAsync()
    {
        Submissions = await ItemService.GetLatestSubmissionsAsync(20);
    }
}
