@page "/"
@layout LandingLayout
@using System.Security.Claims
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@inject NavigationManager Navigation

<PageTitle>ToolPool — Borrow tools from your neighbors</PageTitle>

<div class="lp">
    @* TOPBAR *@
    <header class="lp-topbar">
        <div class="lp-topbar-inner">
            <a class="lp-wordmark" href="/">Tool<em>Pool</em></a>
            <nav class="lp-nav">
                <a href="#how">How it works</a>
                <a href="#trust">Trust &amp; safety</a>
                <a href="#faq">FAQ</a>
            </nav>
            <div class="row gap-sm">
                @if (IsAuthenticated)
                {
                    <a class="btn btn-ghost" href="/profile" style="padding: 0.5rem 0.9rem; font-size: 0.88rem;">Profile</a>
                }
                else
                {
                    <a class="btn btn-ghost" href="/login" style="padding: 0.5rem 0.9rem; font-size: 0.88rem;">Sign in</a>
                }
                <a class="btn btn-primary" href="/browse" style="padding: 0.55rem 1rem; font-size: 0.88rem;">
                    Get started
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" /></svg>
                </a>
            </div>
        </div>
    </header>

    @* HERO *@
    <section class="lp-hero">
        <div class="lp-hero-inner">
            <div class="lp-hero-copy">
                <span class="badge badge-accent" style="margin-bottom: 1.25rem;">
                    <span class="dot"></span> Now serving Greater Boston
                </span>
                <h1 class="lp-h1">
                    The tools you need,<br />
                    <em>three doors down.</em>
                </h1>
                <p class="lp-lead">
                    ToolPool is a neighborhood library for power tools, ladders, and the random thing you only need once. Borrow from your neighbors. Lend what's gathering dust. Skip the trip to the hardware store.
                </p>
                <div class="row gap-sm wrap" style="margin-top: 1.5rem;">
                    <a class="btn btn-primary btn-lg" href="/browse">
                        Browse tools near me
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" /></svg>
                    </a>
                    <a class="btn btn-secondary btn-lg" href="/browse">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" /></svg>
                        List your tools
                    </a>
                </div>
                <div class="row gap-lg wrap lp-trust-row" style="margin-top: 2rem;">
                    <span>
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" /></svg>
                        Refundable deposit
                    </span>
                    <span>
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2" /><path d="M7 11V7a5 5 0 0 1 10 0v4" /></svg>
                        Address kept private
                    </span>
                    <span>
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
                        Stripe-secured payments
                    </span>
                </div>
            </div>

            @* HERO COLLAGE *@
            <div class="lp-hero-art">
                <div class="lp-collage-card-bg">
                    <div class="lp-collage-thumb">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" /></svg>
                    </div>
                    <div style="padding: 1rem 1.1rem;">
                        <div class="muted" style="font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.6px;">Power Tools</div>
                        <div style="font-family: 'Lora', serif; font-weight: 600; font-size: 1rem; margin-top: 0.2rem;">DeWalt 20V Hammer Drill</div>
                        <div class="row between" style="margin-top: 0.65rem; padding-top: 0.65rem; border-top: 1px solid var(--divide);">
                            <span class="muted" style="font-size: 0.8rem;">📍 0.4 mi</span>
                            <span style="font-weight: 600;">$18<span class="muted" style="font-weight: 400; font-size: 0.78rem;">/day</span></span>
                        </div>
                    </div>
                </div>

                <div class="lp-collage-card-fg">
                    <div class="row gap-sm" style="margin-bottom: 0.6rem;">
                        <div style="width: 28px; height: 28px; border-radius: 50%; background: var(--accent); color: white; display: grid; place-items: center;">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
                        </div>
                        <span style="font-weight: 600; font-size: 0.92rem;">Maria approved your booking</span>
                    </div>
                    <div class="muted" style="font-size: 0.82rem; line-height: 1.5; margin-left: 2.3rem;">
                        Pickup Sat 10–11 AM<br />
                        47 Forest Hills St — revealed
                    </div>
                </div>

                <div class="lp-collage-chip">
                    <span class="dot pulse" style="background: var(--accent);"></span>
                    <span>3 new tools nearby</span>
                </div>

                <svg class="lp-collage-glyph" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 2l1.7 6.3L20 10l-6.3 1.7L12 18l-1.7-6.3L4 10l6.3-1.7z" />
                </svg>
            </div>
        </div>

        @* STAT STRIP *@
        <div class="lp-stats">
            <div class="lp-stat"><span class="lp-stat-v">1,240+</span><span class="lp-stat-k">Tools listed</span></div>
            <div class="lp-stat"><span class="lp-stat-v">27</span><span class="lp-stat-k">Boston neighborhoods</span></div>
            <div class="lp-stat"><span class="lp-stat-v">4.8 ★</span><span class="lp-stat-k">Average rental</span></div>
            <div class="lp-stat"><span class="lp-stat-v">$0</span><span class="lp-stat-k">Deposit when returned on time</span></div>
        </div>
    </section>

    @* HOW IT WORKS *@
    <section class="lp-section" id="how">
        <div class="lp-section-head">
            <span class="eyebrow">How it works</span>
            <h2 class="lp-h2">Borrow a drill in three taps.</h2>
            <p class="lp-section-lead">No memberships. No long forms. Just neighbors helping neighbors get the job done.</p>
        </div>

        <div class="lp-how-grid">
            <div class="lp-how-card">
                <div class="row between" style="align-items: flex-start;">
                    <span class="lp-how-num">01</span>
                    <div class="lp-how-icon">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" /><circle cx="12" cy="10" r="3" /></svg>
                    </div>
                </div>
                <h3 style="margin: 1.5rem 0 0.5rem;">Find a tool nearby</h3>
                <p class="muted" style="font-size: 0.92rem; line-height: 1.65;">Browse drills, ladders, pressure washers — and 200+ more — in your neighborhood. Approximate locations only, until you book.</p>
            </div>

            <div class="lp-how-card">
                <div class="row between" style="align-items: flex-start;">
                    <span class="lp-how-num">02</span>
                    <div class="lp-how-icon">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
                    </div>
                </div>
                <h3 style="margin: 1.5rem 0 0.5rem;">Request &amp; get confirmed</h3>
                <p class="muted" style="font-size: 0.92rem; line-height: 1.65;">Pay to reserve. The owner picks a pickup window. Address is shared the moment they approve — never before.</p>
            </div>

            <div class="lp-how-card">
                <div class="row between" style="align-items: flex-start;">
                    <span class="lp-how-num">03</span>
                    <div class="lp-how-icon">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11V7a3 3 0 0 1 6 0v4" /><path d="M5 11h14l-1 9a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2z" /></svg>
                    </div>
                </div>
                <h3 style="margin: 1.5rem 0 0.5rem;">Meet, snap, return</h3>
                <p class="muted" style="font-size: 0.92rem; line-height: 1.65;">A four-digit code and a quick photo confirm the handoff. Return on time and your deposit comes right back.</p>
            </div>
        </div>
    </section>

    @* TOOLS PEEK *@
    <section class="lp-section">
        <div class="row between wrap" style="margin-bottom: 1.5rem; align-items: flex-end;">
            <div>
                <span class="eyebrow">In your neighborhood</span>
                <h2 class="lp-h2" style="margin-top: 0.5rem;">What's available right now.</h2>
            </div>
            <a class="btn btn-secondary" href="/browse">
                See all tools
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" /></svg>
            </a>
        </div>

        <div class="lp-tools-grid">
            <a class="lp-tool-card" href="/browse" style="text-decoration: none; color: inherit;">
                <div class="lp-tool-thumb tone-green">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" /></svg>
                </div>
                <div class="lp-tool-body">
                    <div class="lp-tool-cat">Power Tools</div>
                    <div class="lp-tool-name">DeWalt Hammer Drill</div>
                    <div class="lp-tool-foot">
                        <span class="row gap-sm">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" /><circle cx="12" cy="10" r="3" /></svg>
                            Jamaica Plain
                        </span>
                        <span class="lp-tool-price">$18<span class="per">/day</span></span>
                    </div>
                </div>
            </a>

            <a class="lp-tool-card" href="/browse" style="text-decoration: none; color: inherit;">
                <div class="lp-tool-thumb tone-sand">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><line x1="6" y1="2" x2="6" y2="22" /><line x1="18" y1="2" x2="18" y2="22" /><line x1="6" y1="6" x2="18" y2="6" /><line x1="6" y1="11" x2="18" y2="11" /><line x1="6" y1="16" x2="18" y2="16" /></svg>
                </div>
                <div class="lp-tool-body">
                    <div class="lp-tool-cat">Equipment</div>
                    <div class="lp-tool-name">8-ft Aluminum Ladder</div>
                    <div class="lp-tool-foot">
                        <span class="row gap-sm">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" /><circle cx="12" cy="10" r="3" /></svg>
                            Cambridgeport
                        </span>
                        <span class="lp-tool-price">$12<span class="per">/day</span></span>
                    </div>
                </div>
            </a>

            <a class="lp-tool-card" href="/browse" style="text-decoration: none; color: inherit;">
                <div class="lp-tool-thumb tone-blue">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12c2 0 2-2 4-2s2 2 4 2 2-2 4-2 2 2 4 2" /><path d="M3 18c2 0 2-2 4-2s2 2 4 2 2-2 4-2 2 2 4 2" /><path d="M3 6c2 0 2-2 4-2s2 2 4 2 2-2 4-2 2 2 4 2" /></svg>
                </div>
                <div class="lp-tool-body">
                    <div class="lp-tool-cat">Equipment</div>
                    <div class="lp-tool-name">Pressure Washer 2200W</div>
                    <div class="lp-tool-foot">
                        <span class="row gap-sm">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" /><circle cx="12" cy="10" r="3" /></svg>
                            Somerville
                        </span>
                        <span class="lp-tool-price">$28<span class="per">/day</span></span>
                    </div>
                </div>
            </a>

            <a class="lp-tool-card" href="/browse" style="text-decoration: none; color: inherit;">
                <div class="lp-tool-thumb tone-default">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12h18" /><path d="M5 12V8a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v4" /><path d="M5 12v4a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-4" /></svg>
                </div>
                <div class="lp-tool-body">
                    <div class="lp-tool-cat">Hand Tools</div>
                    <div class="lp-tool-name">Hand Plane Set</div>
                    <div class="lp-tool-foot">
                        <span class="row gap-sm">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" /><circle cx="12" cy="10" r="3" /></svg>
                            Roxbury
                        </span>
                        <span class="lp-tool-price">$9<span class="per">/day</span></span>
                    </div>
                </div>
            </a>
        </div>
    </section>

    @* TRUST *@
    <section class="lp-trust" id="trust">
        <div class="lp-trust-grid">
            <div>
                <span class="eyebrow">Trust &amp; safety</span>
                <h2 class="lp-h2" style="margin-top: 0.5rem; margin-bottom: 1rem;">Built around trust, by design.</h2>
                <p class="muted" style="font-size: 1rem; line-height: 1.7; max-width: 42ch;">
                    We didn't bolt safety on at the end. Every step — from listing to handoff — protects both sides of the rental.
                </p>
            </div>
            <div class="lp-trust-list">
                <div class="lp-trust-item">
                    <div class="lp-trust-icon">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2" /><path d="M7 11V7a5 5 0 0 1 10 0v4" /></svg>
                    </div>
                    <div>
                        <h4>Progressive location</h4>
                        <p>Listings show neighborhoods, not addresses. Exact location is shared only after the owner approves.</p>
                    </div>
                </div>
                <div class="lp-trust-item">
                    <div class="lp-trust-icon">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" /></svg>
                    </div>
                    <div>
                        <h4>Refundable deposit, every time</h4>
                        <p>Stripe holds a deposit for each rental. It's released the moment the tool is returned in good condition.</p>
                    </div>
                </div>
                <div class="lp-trust-item">
                    <div class="lp-trust-icon">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z" /><circle cx="12" cy="13" r="4" /></svg>
                    </div>
                    <div>
                        <h4>Photo handoff at both ends</h4>
                        <p>Pickup and return photos are timestamped to both parties' records. Condition is never a he-said-she-said.</p>
                    </div>
                </div>
                <div class="lp-trust-item">
                    <div class="lp-trust-icon">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /><rect x="14" y="14" width="3" height="3" /><rect x="18" y="18" width="3" height="3" /></svg>
                    </div>
                    <div>
                        <h4>Four-digit confirm code</h4>
                        <p>A short code verifies you actually met. No code, no handoff — and no liability mix-ups.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    @* TESTIMONIAL *@
    <section class="lp-section">
        <div class="lp-quote">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v3M12 18v3M3 12h3M18 12h3M5.6 5.6l2.1 2.1M16.3 16.3l2.1 2.1M5.6 18.4l2.1-2.1M16.3 7.7l2.1-2.1" /></svg>
            <p class="lp-quote-text">
                I was about to drop $180 on a pressure washer for one Saturday. Borrowed Maria's instead for $28, returned it the same day. Took ten minutes. We chatted about her garden.
            </p>
            <div class="lp-quote-author">
                <div class="avatar-lg">JL</div>
                <div>
                    <div style="font-weight: 500; font-size: 0.92rem; color: var(--text);">Jamie Lin</div>
                    <div class="muted" style="font-size: 0.82rem;">Renter · Jamaica Plain</div>
                </div>
            </div>
        </div>
    </section>

    @* FAQ *@
    <section class="lp-section" id="faq">
        <div class="lp-section-head">
            <span class="eyebrow">FAQ</span>
            <h2 class="lp-h2">Questions, answered.</h2>
        </div>
        <div class="lp-faq">
            <details open>
                <summary>What if a tool gets damaged?</summary>
                <div class="lp-faq-body"><div>Every booking includes a refundable deposit held by Stripe. Pickup and return photos document condition automatically — disputes are rare and resolved by our team within 48 hours.</div></div>
            </details>
            <details>
                <summary>How is my address kept private?</summary>
                <div class="lp-faq-body"><div>Your exact address is never shown publicly. Listings only display your neighborhood. The street address is revealed to the renter the moment you approve their request — and only to them.</div></div>
            </details>
            <details>
                <summary>Who can list tools?</summary>
                <div class="lp-faq-body"><div>Any verified Boston resident with a Stripe-connected account. Onboarding takes about three minutes; payouts land in your bank within two business days of return.</div></div>
            </details>
            <details>
                <summary>What if I'm running late?</summary>
                <div class="lp-faq-body"><div>Open the booking and tap 'Request extension'. The owner gets a notification and can approve or decline in one tap — no awkward texts.</div></div>
            </details>
        </div>
    </section>

    @* CTA *@
    <section class="lp-cta">
        <div class="lp-cta-inner">
            <h2 class="lp-h2">Your neighbors have the tool you need.</h2>
            <p>Free to join. Pay only when you borrow. Earn when you lend.</p>
            <div class="lp-cta-row">
                <a class="btn btn-lg btn-on-accent" href="/browse">
                    Get started
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" /></svg>
                </a>
                <a class="btn btn-lg btn-on-accent-outline" href="/browse">List your first tool</a>
            </div>
        </div>
    </section>

    @* FOOTER *@
    <footer class="lp-footer">
        <div class="lp-footer-inner">
            <div>
                <a class="lp-wordmark" href="/">Tool<em>Pool</em></a>
                <p class="muted" style="font-size: 0.85rem; margin-top: 0.6rem; max-width: 32ch;">
                    A neighborhood tool library for Greater Boston. Borrow more, store less.
                </p>
            </div>
            <div class="lp-footer-cols">
                <div>
                    <span class="eyebrow">Product</span>
                    <a href="/browse">Browse</a>
                    <a href="/browse">List a tool</a>
                    <a href="#how">How it works</a>
                </div>
                <div>
                    <span class="eyebrow">Company</span>
                    <a href="#">About</a>
                    <a href="#">Press</a>
                    <a href="#">Contact</a>
                </div>
                <div>
                    <span class="eyebrow">Legal</span>
                    <a href="#">Terms</a>
                    <a href="#">Privacy</a>
                    <a href="#trust">Trust &amp; safety</a>
                </div>
            </div>
        </div>
        <div class="lp-footer-bottom">
            <span>© 2026 ToolPool</span>
            <span>Made in Boston</span>
        </div>
    </footer>
</div>

@code {
    private ClaimsPrincipal? CurrentUser => HttpContextAccessor.HttpContext?.User;
    private bool IsAuthenticated => CurrentUser?.Identity?.IsAuthenticated == true;

    protected override void OnInitialized()
    {
        if (IsAuthenticated)
        {
            Navigation.NavigateTo("/browse", replace: true);
        }
    }
}
