@page "/browse"
@rendermode InteractiveWebAssembly
@using BlazorBootstrap
@using ToolPool.Client.Models
@using ToolPool.Client.Services
@using GoogleMapsComponents
@using GoogleMapsComponents.Maps
@inject ToolService ToolService
@inject NavigationManager Nav
@using System.Text
@inject IJSRuntime JS
@inject HttpClient Http

<h2 class="pageTitle">Discover Tools Near You</h2>
<span class="pageSubtitle">Browse available tools in your neighborhood. Exact locations are revealed after booking.</span>

<div style="display: flex; flex-direction: row">
    @* filters sidebar *@
    <div style="display: flex; flex-direction: column; gap: 1.25rem; width: 25%; border-right: 1px solid var(--divide); margin: 1.25rem; margin-right: 0; padding-right: 1.25rem">
        <h5 style="margin: 0; padding-left: 0.25rem">Filters</h5>

        @* category *@
        <div class="browse-filters">
            <div class="browse-filter-group">
                <span class="browse-filter-label">Tool Types</span>
                <Button Type="ButtonType.Button" Color="ButtonColor.Light" @onclick="ToggleCategories" Disabled="@(!toolsLoaded)">
                    <span style="display: flex; justify-content: space-between; align-items: center">
                        <span>Categories (@(selectedCategories.Count)/@(categoriesList.Count))</span>
                        @if(categoriesExpanded)
                        {
                            <Icon Name="IconName.ChevronUp" />
                        } else
                        {
                            <Icon Name="IconName.ChevronDown" />
                        }
                    </span>
                </Button>
            </div>

            @if (toolsLoaded)
            {
                <div style="width: 100%">
                    <Collapse @ref="categories">
                        <div class="filterOptions">
                            <div class="filterAll">
                                <input type="checkbox" id="allCategories" checked="@(selectedCategories.Count == categoriesList.Count)" @onchange="OnAllCategoriesChanged" />
                                <label for="allCategories" style="margin-left: 5px"><b>All Categories</b></label>
                            </div>

                            <div class="filterCheckboxes">
                                @foreach (var cat in categoriesList)
                                {
                                    <div style="display: flex; align-items: center">
                                        <input type="checkbox" id="@cat" checked="@selectedCategories.Contains(cat)" @onchange="(e) => OnCategoryChanged(cat, (bool)e.Value!)" />
                                        <label for="@cat" style="margin-left: 5px; flex: 1;">@cat</label>
                                    </div>
                                }
                            </div>
                        </div>
                    </Collapse>
                </div>
            }
        </div>

        @* neighborhood *@
        <div class="browse-filters">
            <div class="browse-filter-group">
                <span class="browse-filter-label">Locations</span>
                <Button Type="ButtonType.Button" Color="ButtonColor.Light" @onclick="ToggleNeighborhoods" Disabled="@(!toolsLoaded)">
                    <span style="display: flex; justify-content: space-between; align-items: center">    
                        <span>Neighborhoods (@(selectedNeighborhoods.Count)/@(neighborhoodsList.Count))</span>
                        @if(neighborhoodsExpanded)
                        {
                            <Icon Name="IconName.ChevronUp" />
                        } else
                        {
                            <Icon Name="IconName.ChevronDown" />
                        }
                    </span>
                </Button>
            </div>

            @if (toolsLoaded)
            {
                <div style="width: 100%">
                    <Collapse @ref="neighborhoods">
                        <div class="filterOptions">
                            <div class="filterAll">
                                <input type="checkbox" id="allNeighborhoods" checked="@(selectedNeighborhoods.Count == neighborhoodsList.Count)" @onchange="OnAllNeighborhoodsChanged" />
                                <label for="allNeighborhoods" style="margin-left: 5px"><b>All Neighborhoods</b></label>
                            </div>

                            <div class="filterCheckboxes">
                                @foreach (var n in neighborhoodsList)
                                {
                                    <div style="display: flex; align-items: center;">
                                        <input type="checkbox" id="@n" checked="@selectedNeighborhoods.Contains(n)" @onchange="(e) => OnNeighborhoodChanged(n, (bool)e.Value!)" />
                                        <label for="@n" style="margin-left: 5px">@n</label>
                                    </div>
                                }
                                </div>
                        </div>
                    </Collapse>
                </div>
            }
        </div>
    </div>

    @* tool map/grid section *@
    <div style="display: flex; flex-direction: column; gap: 1.25rem; width: 75%; margin: 1.25rem">
        @* tool name/desc search bar *@
        <div class="browse-filters" style="border: 0; padding-bottom: 0">
            <div class="browse-search-group">
                <span class="browse-filter-label">Search</span>
                <input class="browse-filter-input" type="text" placeholder="Enter tool title..." @bind="searchQuery" @bind:event="oninput" disabled="@(!toolsLoaded)" />
            </div>
        </div>

        @* count and map toggle *@
        <div style="display: flex; align-items: flex-end; justify-content: space-between">
            <h3 class="browse-section-title">Available Tools (@FilteredTools.Count())</h3>
            <Button Type="ButtonType.Button" Color="ButtonColor.Secondary" Size="ButtonSize.Small" @onclick="ToggleMap" Disabled="@(!mapLoaded)">@(mapVisible ? "Hide map" : "Show map")</Button>
        </div>

        @* map loading *@
        @if (!mapLoaded)
        {
            <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; margin: 0">
                <Spinner />
                <i>Loading map...</i>
            </div>
        }

        @* map *@
        <Collapse @ref="displayMap">
            <div class="browse-location-card">
                @* center map input *@
                <div style="display: flex; flex-direction: row; align-items: center; gap: 10px">
                    <h5 style="margin: 0">Choose a location:</h5>
                    <div class="location-search">
                        @* address search  *@
                        <AutoComplete @bind-Value="addressSearch"
                                      TItem="AddressPair"
                                      DataProvider="GetSuggestions"
                                      PropertyName="Address"
                                      StringComparison="StringComparison.OrdinalIgnoreCase"
                                      Placeholder=@locationPlaceholder
                                      OnChanged="AddressSelect"
                                      Disabled="@(!mapLoaded)" />
                    </div>
                </div>

                <div class="browse-location-hint">
                    Displayed locations are approximate. Exact address of tools are revealed after confirmation.
                </div>

                @* map *@
                <div class="map">
                    <AdvancedGoogleMap @ref="map" Options="mapOptions" OnAfterInit="mapRenderDone">
                        @* drawing markers *@
                        @if (toolsLoaded)
                        {
                            @foreach (var m in FilteredTools)
                            {
                                //approxiate location by truncating to 2 decimal points
                                <MarkerComponent @key="m.Id.ToString()"
                                                    Lat="@Math.Round(m.AddressLat, 2, MidpointRounding.ToZero)"
                                                    Lng="@Math.Round(m.AddressLng, 2, MidpointRounding.ToZero)"
                                                    Clickable="true"
                                                    OnClick="@(() => NavigateToTool(m.Id))">
                                    <div style="display: flex; flex-direction: column; align-items: center; text-align: center">
                                        <h6 style="background: white; padding: 5px; border-radius: 5px">@(m.Name.Length > 20 ? $"{m.Name.Substring(0,20)}..." : m.Name) - @m.Price.ToString("C")</h6>
                                        <Image Src="/browse.png" Alt="Browse" />
                                        <span style="background: white; padding: 5px; border-radius: 5px">@m.OwnerName</span>
                                    </div>
                                </MarkerComponent>
                            }
                        }
                    </AdvancedGoogleMap>
                </div>
            </div>
        </Collapse>

        @* tools grid *@
        @if (!toolsLoaded)
        {
            <div class="browse-loading">
                <Spinner />
                <p>Loading tools...</p>
            </div>
        }
        else if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="browse-empty">
                <p>@errorMessage</p>
            </div>
        }
        else if (!FilteredTools.Any())
        {
            <div class="browse-empty">
                <p>No tools found matching your filters.</p>
            </div>
        }
        else
        {
            <div class="browse-grid">
                @foreach (var item in FilteredTools)
                {
                    var bgColor = GetBgColor(item.Category);
                    <div class="browse-card">
                        <div class="browse-card-image" style="background: @bgColor">
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" alt="@item.Name" class="browse-card-img" />
                            }
                            <span class="browse-card-category-tag">@(string.IsNullOrEmpty(item.Category) ? "General" : item.Category)</span>
                        </div>
                        <div class="browse-card-body">
                        <div style="display: flex; align-items: center; justify-content: space-between">
                                <h4 class="browse-card-name">@item.Name</h4>
                                <span class="badge text-bg-secondary" style="color: black">@item.Category</span>
                            </div>
                            <div class="browse-card-location">
                                <span class="browse-card-loc-icon">📍</span>
                                <span>@(string.IsNullOrEmpty(item.Neighborhood) ? "Nearby" : item.Neighborhood)</span>
                            </div>
                            <div class="browse-card-owner-row">
                                <span class="browse-card-owner">@(string.IsNullOrEmpty(item.OwnerName) ? "Owner" : item.OwnerName)</span>
                            </div>
                            <div class="browse-card-footer">
                                <span class="browse-card-price">@item.Price.ToString("C") / day</span>
                                <button class="browse-card-details-btn" @onclick="() => NavigateToTool(item.Id)">View Details</button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    private string locationPlaceholder;
    private string addressSearch;
    public IEnumerable<AddressPair>? locations;
    private AccountInfo? currentUser;

    //get autocomplete location suggestions
    private async Task<AutoCompleteDataProviderResult<AddressPair>> GetSuggestions(AutoCompleteDataProviderRequest<AddressPair> ap)
    {
        var results = await Http.GetFromJsonAsync<List<AddressPair>>($"api/suggestLocations/{ap.Filter.Value}");
        return new AutoCompleteDataProviderResult<AddressPair>
        {
            Data = results,
            TotalCount = results.Count
        };
    }

    //called after user selects address from autocomplete, recenter map and update placeholder
    private async Task AddressSelect(AddressPair? ap)
    {
        if(ap.PlaceId != null) {
            var coords = await Http.GetFromJsonAsync<Location>($"api/getCoordinates/{ap.PlaceId}");
            locationPlaceholder = await ToolService.ReverseGeocode(coords.Latitude.ToString(), coords.Longitude.ToString());
            await map.InteropObject.SetCenter(new LatLngLiteral(coords.Latitude, coords.Longitude));
        }
    }

    private List<Tool> allTools = new();
    private bool toolsLoaded = false;
    private string? errorMessage;
    private string searchQuery = "";

    //category filter vars
    private List<String> selectedCategories = new();
    Collapse categories = default!;
    private List<String> categoriesList = new();
    private bool categoriesExpanded = false;
    private async Task ToggleCategories()
    {
        await categories.ToggleAsync();
        categoriesExpanded = !categoriesExpanded;
    }

    //neighborhood filter vars
    private List<String> selectedNeighborhoods = new();
    Collapse neighborhoods = default!;
    private List<String> neighborhoodsList = new();
    private bool neighborhoodsExpanded = false;
    private async Task ToggleNeighborhoods()
    {
        await neighborhoods.ToggleAsync();
        neighborhoodsExpanded = !neighborhoodsExpanded;
    }

    //map variables
    private static LatLngLiteral startingCenter = new LatLngLiteral(42.3604, -71.0580); //city hall
    private bool mapLoaded = false;
    private AdvancedGoogleMap map;
    private MapOptions mapOptions = new MapOptions()
    {
        Zoom = 16,
        Center = startingCenter, //city hall
        MapId = "39cf637b3be049e5f469447c", //custom map and style
        MapTypeId = MapTypeId.Roadmap,
        MapTypeControl = false,
        StreetViewControl = false
    };
    bool mapVisible = false;
    Collapse displayMap = default!;
    private async Task ToggleMap()
    {
        await displayMap.ToggleAsync();
        mapVisible = !mapVisible;
    }

    //view tool details
    private void NavigateToTool(Guid id) => Nav.NavigateTo($"/express_interest/{id}");

    // called once the map renders
    private async Task mapRenderDone()
    {
        mapLoaded = true;

        //request browser location and center map
        try
        {
            var browserLocation = await JS.InvokeAsync<Location>("getBrowserLocation");
            Console.WriteLine($"browser location successful: ({browserLocation.Latitude}, {browserLocation.Longitude})");
            await map.InteropObject.SetCenter(new LatLngLiteral(browserLocation.Latitude, browserLocation.Longitude));
            locationPlaceholder = await ToolService.ReverseGeocode(browserLocation.Latitude.ToString(), browserLocation.Longitude.ToString());
        } catch (Exception ex)
        {
            Console.WriteLine($"browser location ERROR: {ex.Message}");
        }
    }

    //get tools, categories, neighborhoods
    protected override async Task OnInitializedAsync()
    {
        try
        {
            locationPlaceholder = await ToolService.ReverseGeocode(startingCenter.Lat.ToString(), startingCenter.Lng.ToString());

            allTools = await ToolService.GetToolsAsync();
            if (!allTools.Any())
            {
                errorMessage = "No tools exist.";
            }

            var profileResponse = await Http.GetAsync(Nav.ToAbsoluteUri("/api/profile/me"));

            //filter out user's own tools
            if (profileResponse.IsSuccessStatusCode)
            {
                currentUser = await profileResponse.Content.ReadFromJsonAsync<AccountInfo>();
                if (currentUser is not null)
                {
                    allTools = allTools.Where(t => t.OwnerId != currentUser.Id).ToList();
                }
            }
            else
            {
                currentUser = null;
            }

            //set filter options
            foreach (var t in allTools)
            {
                if (!categoriesList.Contains(t.Category))
                {
                    categoriesList.Add(t.Category);
                }
                if (!neighborhoodsList.Contains(t.Neighborhood))
                {
                    neighborhoodsList.Add(t.Neighborhood);
                }
            }
            if(categoriesList.Contains("Other")) //always put 'other' at the end
            {
                categoriesList.Remove("Other");
                categoriesList.Add("Other");
            }
            selectedCategories = new List<string>(categoriesList);
            selectedNeighborhoods = new List<string>(neighborhoodsList);
        }
        catch (Exception ex)
        {
            allTools = new List<Tool>();
            errorMessage = $"Could not load tools: {ex.Message}";
        }

        toolsLoaded = true;
    }

    //all filter options
    private void OnAllNeighborhoodsChanged(ChangeEventArgs e)
    {
        if ((bool)e.Value!)
        {
            selectedNeighborhoods = new List<string>(neighborhoodsList);
        }
        else
        {
            selectedNeighborhoods.Clear();
        }
    }
    private void OnAllCategoriesChanged(ChangeEventArgs e)
    {
        if ((bool)e.Value!)
        {
            selectedCategories = new List<string>(categoriesList);
        }
        else
        {
            selectedCategories.Clear();
        }
    }

    //individual filter options
    private void OnNeighborhoodChanged(string neighborhood, bool isChecked)
    {
        if (isChecked)
        {
            selectedNeighborhoods.Add(neighborhood);
        }
        else
        {
            selectedNeighborhoods.Remove(neighborhood);
        }
    }
    private void OnCategoryChanged(string category, bool isChecked)
    {
        if (isChecked)
        {
            selectedCategories.Add(category);
        }
        else
        {
            selectedCategories.Remove(category);
        }
    }

    //tool filtering
    private IEnumerable<Tool> FilteredTools
    {
        get
        {
            var result = allTools.AsEnumerable();

            //filter based on tool name or description
            if (!string.IsNullOrWhiteSpace(searchQuery))
            {
                var q = searchQuery.Trim();
                result = result.Where(t =>
                    t.Name.Contains(q, StringComparison.OrdinalIgnoreCase) ||
                    t.Description.Contains(q, StringComparison.OrdinalIgnoreCase));
            }

            //apply category/neighborhood filters
            if (selectedCategories.Any())
            {
                result = result.Where(t => selectedCategories.Contains(t.Category));
                result = result.Where(t => selectedNeighborhoods.Contains(t.Neighborhood));
            } else
            {
                result = Enumerable.Empty<Tool>();
            }

            return result;
        }
    }

    private static string GetBgColor(string category) => category switch
    {
        "Power Tools" => "#e8e4de",
        "Hand Tools" => "#e0e8df",
        "Equipment" => "#e4dfe8",
        "Garden" => "#dde8dd",
        "Cleaning" => "#dde5e8",
        _ => "#e8e4de"
    };

    
    private sealed class AccountInfo
    {
        public Guid Id { get; set; }
        public string Username { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;

        [System.Text.Json.Serialization.JsonPropertyName("created_at")]
        public DateTimeOffset? CreatedAt { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("updated_at")]
        public DateTimeOffset? UpdatedAt { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("stripe_account_id")]
        public string? StripeAccountId { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("sendbird_user_id")]
        public string? SendbirdUserId { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("stripe_customer_id")]
        public string? StripeCustomerId { get; set; }

        public DateTimeOffset JoinedAt => CreatedAt?.ToLocalTime() ?? DateTimeOffset.Now;
    }
}
