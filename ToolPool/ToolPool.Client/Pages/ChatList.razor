@page "/chat"
@rendermode InteractiveWebAssembly
@using System.Text.Json.Serialization
@using ToolPool.Client.Models
@using ToolPool.Client.Services
@inject ToolService ToolService
@inject NavigationManager Nav
@inject HttpClient Http


<div class="chat-list-container">
    <div class="chat-list-header">
        <h1>Messages</h1>
    </div>

    @if (!authChecked)
    {
        <p class="chat-loading-text">Loading...</p>
    }
    else if (currentUser is null)
    {
        <div class="chat-start-section">
            <h3>Please Log In</h3>
            <p>You need to be logged in to view your messages.</p>
            <button class="chat-start-btn" @onclick='() => Nav.NavigateTo("/login")'>Log In</button>
        </div>
    }
    else
    {
        <div class="chat-channels-section">
            <h3>Your Conversations</h3>

            @if (isLoadingInterests)
            {
                <p class="chat-loading-text">Loading conversations...</p>
            }
            else if (!interests.Any())
            {
                <p class="chat-empty-text">No conversations yet. Browse tools and express interest to start chatting.</p>
                <button class="chat-start-btn" @onclick='() => Nav.NavigateTo("/browse")'>Browse Tools</button>
            }
            else
            {
                <div class="chat-channel-list">
                    @foreach (var item in interests)
                    {
                        @if (!string.IsNullOrEmpty(item.ChannelUrl))
                        {
                            <a href="/chat/@item.ChannelUrl?interestId=@item.Id" class="chat-channel-card">
                                <div style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
                                    <div>
                                        <span class="chat-channel-name">@item.ToolName</span>
                                        <span class="chat-channel-meta">
                                            @(item.Role == "renter" ? "Owner" : "Renter"): @item.CounterpartName
                                        </span>
                                    </div>
                                    <div style="text-align: right;">
                                        <span class="chat-channel-meta" style="text-transform: capitalize;">@item.Status</span>
                                        @if (item.CreatedAt.HasValue)
                                        {
                                            <br />
                                            <span class="chat-channel-meta" style="font-size: 0.75em;">@item.CreatedAt.Value.LocalDateTime.ToString("MMM d")</span>
                                        }
                                    </div>
                                </div>
                            </a>
                        }
                        else
                        {
                            <div class="chat-channel-card" style="opacity: 0.6; cursor: default;">
                                <div>
                                    <span class="chat-channel-name">@item.ToolName</span>
                                    <span class="chat-channel-meta">
                                        @(item.Role == "renter" ? "Owner" : "Renter"): @item.CounterpartName
                                    </span>
                                </div>
                                <span class="chat-channel-meta">Chat pending</span>
                            </div>
                        }
                    }
                </div>
            }

            <button class="chat-refresh-btn" @onclick="LoadInterests">Refresh</button>
        </div>
    }

    @if (!string.IsNullOrEmpty(errorMsg))
    {
        <p class="chat-error-msg">@errorMsg</p>
    }
</div>

@code {
    private AccountInfo? currentUser;
    private bool authChecked = false;
    private bool isLoadingInterests = false;
    private string errorMsg = "";
    private List<MyInterestItem> interests = new();

    private bool _loaded = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _loaded) return;
        _loaded = true;

        currentUser = await Http.GetFromJsonAsync<AccountInfo>(Nav.ToAbsoluteUri("/api/profile/me"));
        authChecked = true;

        if (currentUser is not null)
            await LoadInterests();

        StateHasChanged();
    }

    private async Task LoadInterests()
    {
        isLoadingInterests = true;
        errorMsg = "";
        try
        {
            interests = await ToolService.GetMyInterestsAsync(currentUser.Id);
        }
        catch (Exception ex)
        {
            errorMsg = $"Failed to load conversations: {ex.Message}";
        }
        finally
        {
            isLoadingInterests = false;
        }
    }

    private sealed class AccountInfo
    {
        public Guid Id { get; set; }
        public string Username { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;

        [System.Text.Json.Serialization.JsonPropertyName("created_at")]
        public DateTimeOffset? CreatedAt { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("updated_at")]
        public DateTimeOffset? UpdatedAt { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("stripe_account_id")]
        public string? StripeAccountId { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("sendbird_user_id")]
        public string? SendbirdUserId { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("stripe_customer_id")]
        public string? StripeCustomerId { get; set; }

        public DateTimeOffset JoinedAt => CreatedAt?.ToLocalTime() ?? DateTimeOffset.Now;
    }
}
