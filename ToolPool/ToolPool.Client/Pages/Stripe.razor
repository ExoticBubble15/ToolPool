@page "/stripe"
@rendermode InteractiveWebAssembly
@using ToolPool.Client.Models
@using ToolPool.Client.Services
@using System.Globalization
@inject DemoItemService ItemService
@inject CartService Cart
@inject HttpClient Http
@inject NavigationManager Nav

<div class="page-wrap">
    <div class="page-hero">
        <h1>Tool Pool</h1>
        <p>Add a Tool.</p>
    </div>

    @* STRIPE ONBOARDING BLOCK *@
    @if (!HasStripeOnboarded)
    {
        <div class="item-card suggest-card" style="margin-bottom: 1rem;">
            <div class="item-info">
                <h3>Complete Stripe Setup</h3>
                <p>You must finish Stripe onboarding before you can receive payments.</p>
            </div>

            <button class="btn-submit" @onclick="GoToStripeOnboarding">
                Complete Stripe Onboarding →
            </button>
        </div>
    }

    <div class="suggest-wrap">
        <div class="item-card suggest-card">
            <div class="item-info">
                <h3>Add a Tool</h3>
                <p>Add a tool you want to share or rent out.</p>
            </div>

            <div class="submit-grid">
                <input class="submit-input" placeholder="Tool name" @bind="FormName" />
                <input class="submit-input" placeholder="Short description" @bind="FormDescription" />
                <input class="submit-input" placeholder="Image URL" @bind="FormImageUrl" />
                <input class="submit-input" placeholder="Category" @bind="FormCategory" />
                <input class="submit-input" placeholder="Neighborhood" @bind="FormNeighborhood" />

                <input class="submit-input" type="number" step="0.01" min="0"
                       placeholder="Daily price (USD)" @bind="FormPriceText" />
            </div>

            <div class="submit-actions">
                <button class="btn-submit"
                        @onclick="SubmitDemoItem"
                        disabled="@IsSubmitting || !HasStripeOnboarded">
                    @(IsSubmitting ? "Submitting..." : "Submit Tool")
                </button>
            </div>

            @if (!string.IsNullOrWhiteSpace(SubmitMessage))
            {
                <span class="submit-msg @(SubmitOk ? "ok" : "err")">@SubmitMessage</span>
            }
        </div>
    </div>

    @*
    <div class="item-grid">
        @foreach (var item in Items)
        {
            var inCart = Cart.IsInCart(item.Id);

            <div class="item-card @(inCart ? "in-cart" : "")">
                <div class="item-info">
                    <h3>@item.Name</h3>
                    <p>@item.Description</p>
                </div>

                <div class="item-footer">
                    <span class="item-price">$@item.Price.ToString("F2")</span>

                    <button class="@(inCart ? "btn-remove" : "btn-add")"
                            @onclick="() => Toggle(item)">
                        @(inCart ? "Added" : "+ Add")
                    </button>

                    <button class="btn-delete"
                            @onclick="() => DeleteItem(item)"
                            title="Delete item">
                        Delete Item
                    </button>
                </div>
            </div>
        }
    </div>
    *@

    @if (Cart.Count > 0)
    {
        <div class="sticky-bar">
            <span>@Cart.Count item(s) · $@Cart.Total.ToString("F2")</span>
            <a href="/cart" class="btn-checkout-sticky">View Cart →</a>
        </div>
    }
</div>

@code {
    private List<DemoItem> Items = new();

    private string FormName = "";
    private string FormDescription = "";
    private string FormImageUrl = "";
    private string FormCategory = "";
    private string FormNeighborhood = "";
    private string FormPriceText = "";

    private bool IsSubmitting = false;
    private string SubmitMessage = "";
    private bool SubmitOk = false;

    private bool HasStripeOnboarded = false;

    private string OwnerId = "demo-user-123";
    private string OwnerName = "Demo User";

    protected override async Task OnInitializedAsync()
    {
        Items = await ItemService.GetDemoItemsAsync();
        Cart.OnChange += StateHasChanged;

        HasStripeOnboarded = await CheckStripeAsync();
    }

    private async Task GoToStripeOnboarding()
    {
        try
        {
            Console.WriteLine("CLICKED STRIPE BUTTON");

            var accountId = "acct_1TMcZcRpqfBSKA4N";

            var response = await Http.PostAsync(
                $"/api/stripe/create-onboarding-link/{accountId}",
                null
            );

            var url = await response.Content.ReadAsStringAsync();

            Nav.NavigateTo(url.Trim('"'), forceLoad: true);
        }
        catch (Exception ex)
        {
            Console.WriteLine("STRIPE ERROR: " + ex.Message);
        }
    }

    private async Task<bool> CheckStripeAsync()
    {
        var accountId = "acct_1TMcZcRpqfBSKA4N"; // later replace with variable user id

        return await Http.GetFromJsonAsync<bool>(
            $"/api/stripe/onboarding-status/{accountId}"
        );
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Cart.LoadAsync();
            StateHasChanged();
        }
    }

    private async Task SubmitDemoItem()
    {
        SubmitMessage = "";
        SubmitOk = false;

        if (!HasStripeOnboarded)
        {
            SubmitMessage = "You must complete Stripe onboarding first.";
            return;
        }

        if (string.IsNullOrWhiteSpace(FormName))
        {
            SubmitMessage = "Name is required.";
            return;
        }

        if (!decimal.TryParse(FormPriceText, NumberStyles.Number, CultureInfo.InvariantCulture, out var price) || price < 0)
        {
            SubmitMessage = "Enter a valid non-negative price (e.g. 12.34).";
            return;
        }

        IsSubmitting = true;

        try
        {
            await ItemService.InsertSubmissionAsync(
                FormName.Trim(),
                FormDescription.Trim(),
                price,
                FormImageUrl.Trim(),
                OwnerId,
                FormCategory.Trim(),
                OwnerName,
                FormNeighborhood.Trim()
            );

            await ItemService.InsertDemoItemAsync(
                FormName.Trim(),
                FormDescription.Trim(),
                price
            );

            Items = await ItemService.GetDemoItemsAsync();

            SubmitOk = true;
            SubmitMessage = "Submitted successfully.";

            FormName = "";
            FormDescription = "";
            FormImageUrl = "";
            FormCategory = "";
            FormNeighborhood = "";
            FormPriceText = "";
        }
        catch (Exception ex)
        {
            SubmitMessage = $"Submit failed: {ex.Message}";
        }
        finally
        {
            IsSubmitting = false;
        }
    }

    private async void Toggle(DemoItem item)
    {
        if (Cart.IsInCart(item.Id))
        {
            var cartItem = Cart.Items.First(i => i.DemoItemId == item.Id);
            await Cart.RemoveAsync(cartItem.Id);
        }
        else
        {
            await Cart.AddAsync(item);
        }

        Cart.NotifyChanged();
    }

    private async Task DeleteItem(DemoItem item)
    {
        if (Cart.IsInCart(item.Id))
        {
            var cartItem = Cart.Items.First(i => i.DemoItemId == item.Id);
            await Cart.RemoveAsync(cartItem.Id);
            Cart.NotifyChanged();
        }

        await ItemService.DeleteDemoItemAsync(item.Id);
        Items = await ItemService.GetDemoItemsAsync();
    }

    public void Dispose()
    {
        Cart.OnChange -= StateHasChanged;
    }
}