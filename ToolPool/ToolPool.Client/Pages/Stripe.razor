@page "/stripe"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using BlazorBootstrap
@using ToolPool.Client.Models
@using ToolPool.Client.Services
@using System.Globalization
@using System.Net
@using Microsoft.AspNetCore.Components.Forms
@inject ToolService ItemService
@inject CartService Cart
@inject HttpClient Http
@inject NavigationManager Nav
@using System.Net.Http.Json 
@inject ToolService ToolService
@using Philiprehberger.Geolocation;

<h2 class="pageTitle">Upload a Tool</h2>
<span class="pageSubtitle">Post a tool for others to view.</span>

@* STRIPE ONBOARDING BLOCK *@
@if (!HasStripeOnboarded)
{
    <div class="item-card suggest-card" style="margin-bottom: 1rem;">
        <div class="item-info">
            <h3>Complete Stripe Setup</h3>
            <p>You must finish Stripe onboarding before you can receive payments.</p>
        </div>

        <button class="btn-submit" @onclick="GoToStripeOnboarding">
            Complete Stripe Onboarding →
        </button>
    </div>
}

@* ADD TOOL FORM *@
<div class="browse-location-card">

    <div class="browse-filter-group">
        <span class="browse-filter-label">Title*</span>
        <TextInput @bind-Value="@toolSubmission.Name" Placeholder="Title" />
    </div>

    <div class="browse-filter-group">
        <span class="browse-filter-label">Price</span>
        <CurrencyInput @bind-Value="@toolSubmission.Price" TValue="decimal" />
    </div>

    <div class="browse-filter-group">
        <span class="browse-filter-label">Description*</span>
        <TextInput @bind-Value="@toolSubmission.Description" Placeholder="Description" />
    </div>

    @if (categoriesLoaded)
    {
        <div class="browse-filter-group">
            <span class="browse-filter-label">Category*</span>
            <Button Type="ButtonType.Button" Color="ButtonColor.Light" @onclick="ToggleCategories"> Category @(toolSubmission.Category == string.Empty ? "" : $"({toolSubmission.Category})") ⌵</Button>

            <Collapse @ref="categoriesMenu">
                <InputRadioGroup @bind-Value="toolSubmission.Category">
                    @foreach (var c in categoriesList)
                    {
                        <div style="display: flex; align-items: center;">
                            <InputRadio id="@c" Value="@c" />
                            <label for="@c" style="margin-left: 5px">@c</label>
                        </div>
                    }
                </InputRadioGroup>
            </Collapse>
        </div>
    }

    <div class="browse-search-group">
        <span class="browse-filter-label">Location*</span>
        <span class="location-search">
            <AutoComplete @bind-Value="addressSearch"
                          TItem="AddressPair"
                          DataProvider="GetSuggestions"
                          PropertyName="Address"
                          StringComparison="StringComparison.OrdinalIgnoreCase"
                          Placeholder=@locationPlaceholder
                          OnChanged="AddressSelect" />
        </span>
    </div>

    <div class="browse-search-group">
        <span class="browse-filter-label">Image</span>
        <div class="image-drop-zone">
            <InputFile class="image-drop-input"
                       OnChange="HandleImageFileSelected"
                       accept="image/*" />
            <div class="image-drop-content">
                <strong>Drag & drop an image here</strong>
                <span>or click to choose a file (max 5MB)</span>
            </div>
        </div>

        <div class="image-url-row">
            <input class="image-url-input"
                   @bind="imageUrlInput"
                   placeholder="Or paste an image URL" />
            <button type="button" class="btn-submit image-url-btn" @onclick="ApplyImageUrl">Use URL</button>
        </div>

        @if (!string.IsNullOrWhiteSpace(ImagePreviewUrl))
        {
            <div class="image-preview-wrap">
                <img class="image-preview" src="@ImagePreviewUrl" alt="Image preview" />
            </div>
        }
    </div>

    @* SUBMIT TOOL *@
    <i>* fields are required</i>
    <Button Color="ButtonColor.Success" @onclick="SubmitTool" Disabled="@(MissingFields() || IsSubmitting)">
        @(IsSubmitting ? "Submitting..." : "Submit Tool")
    </Button>
    @if (IsSubmitting)
    {
        <div class="submit-loading">
            <Spinner Size="SpinnerSize.Small" />
            <span>Uploading and saving your tool...</span>
        </div>
    }
</div>


@if (!string.IsNullOrWhiteSpace(SubmitMessage))
{
    <span class="submit-msg @(SubmitOk ? "ok" : "err")">@SubmitMessage</span>
} 

@* USER'S TOOL LISTINGS *@
<div class="item-grid">
    @if (Items.Count == 0)
    {
        <p>No tools listed yet.</p>
    }
    else
    {
        @foreach (var item in Items)
        {
            var inCart = Cart.IsInCart(item.Id);

            <div class="item-card @(inCart ? "in-cart" : "")">
                <div class="item-info">
                    <h3>@item.Name</h3>
                    <p>@item.Description</p>
                </div>

                <div class="item-footer">
                    <span class="item-price">$@item.Price.ToString("F2")</span>

                    @* <button class="@(inCart ? "btn-remove" : "btn-add")"
                            @onclick="() => Toggle(item)">
                        @(inCart ? "Added" : "+ Add")
                    </button> *@

                    <button class="btn-delete"
                            @onclick="() => DeleteItem(item)">
                        Delete Item
                    </button>
                </div>
            </div>
        }
    }
</div>

@if (Cart.Count > 0)
{
    <div class="sticky-bar">
        <span>@Cart.Count item(s) · $@Cart.Total.ToString("F2")</span>
        <a href="/cart" class="btn-checkout-sticky">View Cart →</a>
    </div>
}

@code {
    private Tool toolSubmission = new Tool();
    Collapse categoriesMenu = default!;
    private List<String> categoriesList;
    private bool categoriesLoaded = false;
    private async Task ToggleCategories()
    {
        await categoriesMenu.ToggleAsync();
    }

    private string locationPlaceholder = "Search for a location";
    private string addressSearch;

    private async Task<AutoCompleteDataProviderResult<AddressPair>> GetSuggestions(AutoCompleteDataProviderRequest<AddressPair> ap)
    {
        var results = await Http.GetFromJsonAsync<List<AddressPair>>($"api/suggestLocations/{ap.Filter.Value}");
        return new AutoCompleteDataProviderResult<AddressPair>
        {
            Data = results,
            TotalCount = results.Count
        };
    }

    private async Task AddressSelect(AddressPair ap)
    {
        var coords = await Http.GetFromJsonAsync<Location>($"api/getCoordinates/{ap.PlaceId}");
        locationPlaceholder = await ToolService.ReverseGeocode(coords.Latitude.ToString(), coords.Longitude.ToString());
        toolSubmission.AddressLat = coords.Latitude;
        toolSubmission.AddressLng = coords.Longitude;
    }


    private List<Tool> Items = new();

    private bool IsSubmitting = false;
    private string SubmitMessage = "";
    private bool SubmitOk = false;

    private bool HasStripeOnboarded = false;
    private string imageUrlInput = "";
    private string? uploadedImagePreview;
    private const long MaxImageSize = 5 * 1024 * 1024;

    private Guid OwnerId;
    private string OwnerName = "";
    private string? StripeAccountId;

    protected override async Task OnInitializedAsync()
    {
        Cart.OnChange += StateHasChanged;

        var hasUser = await LoadCurrentUserAsync();
        if (!hasUser)
        {
            return;
        }

        var stripeTask = CheckStripeAsync();
        var toolsTask = LoadUserToolsAsync();
        var categoriesTask = ToolService.GetCategoriesAsync();

        await Task.WhenAll(stripeTask, toolsTask, categoriesTask);

        HasStripeOnboarded = await stripeTask;
        categoriesList = await categoriesTask;
        categoriesLoaded = true;
    }

    private async Task LoadUserToolsAsync()
    {
        var allTools = await ItemService.GetToolsAsync();

        Items = allTools
            .Where(t => t.OwnerId == OwnerId)
            .ToList();
    }

    private async Task<bool> LoadCurrentUserAsync()
    {
        var response = await Http.GetAsync(Nav.ToAbsoluteUri("/api/profile/me"));
        if (response.StatusCode == HttpStatusCode.Unauthorized)
        {
            Nav.NavigateTo("/", forceLoad: true);
            return false;
        }

        if (!response.IsSuccessStatusCode)
        {
            var body = await response.Content.ReadAsStringAsync();
            throw new InvalidOperationException($"Failed to load profile: {response.StatusCode} - {body}");
        }

        var me = await response.Content.ReadFromJsonAsync<AccountInfo>();

        if (me is null)
            throw new InvalidOperationException("Failed to parse current user profile.");

        OwnerId = me.Id;
        OwnerName = me.Username ?? "";
        StripeAccountId = me.StripeAccountId;

        toolSubmission.OwnerId = OwnerId;
        toolSubmission.OwnerName = OwnerName;
        return true;
    }

    private async Task GoToStripeOnboarding()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(StripeAccountId))
            {
                SubmitMessage = "No Stripe account found.";
                SubmitOk = false;
                return;
            }

            var response = await Http.PostAsync(
                Nav.ToAbsoluteUri($"/api/stripe/create-onboarding-link/{StripeAccountId}"),
                null
            );

            if (!response.IsSuccessStatusCode)
            {
                SubmitMessage = $"Failed to create onboarding link: {(int)response.StatusCode}";
                SubmitOk = false;
                return;
            }

            var url = await response.Content.ReadAsStringAsync();
            Nav.NavigateTo(url.Trim('"'), forceLoad: true);
        }
        catch (Exception ex)
        {
            SubmitMessage = $"Stripe error: {ex.Message}";
        }
    }

    private async Task<bool> CheckStripeAsync()
    {
        if (string.IsNullOrWhiteSpace(StripeAccountId))
            return false;

        return await Http.GetFromJsonAsync<bool>(
            Nav.ToAbsoluteUri($"/api/stripe/onboarding-status/{StripeAccountId}")
        );
    }

    //field validation
    private bool MissingFields()
    {
        return toolSubmission.Name == String.Empty ||
                toolSubmission.Description == String.Empty ||
                toolSubmission.Price < 0 ||
                toolSubmission.Category == String.Empty ||
                toolSubmission.AddressLat == 0 ||
                toolSubmission.AddressLng == 0;
    }

    private async Task SubmitTool()
    {
        SubmitMessage = "";
        SubmitOk = false;

        if (MissingFields())
        {
            SubmitMessage = "Please fill all required fields before submitting.";
            SubmitOk = false;
            return;
        }

        //set neighborhood as closest to address coords
        if (!HasStripeOnboarded)
        {
            SubmitMessage = "Complete Stripe onboarding first.";
            return;
        }

        IsSubmitting = true;
        var loadingStartedAt = DateTime.UtcNow;
        await InvokeAsync(StateHasChanged);
        await Task.Yield();
        try
        {
            //set neighborhood as closest to address coords
            var neighborhoodTriples = await ToolService.GetNeighborhoodTriples();
            GeoCoordinate addressCord = new GeoCoordinate(toolSubmission.AddressLat, toolSubmission.AddressLng);
            var sorted = neighborhoodTriples.OrderBy(trip => Geo.Distance(new GeoCoordinate(trip.Latitude, trip.Longitude), addressCord, DistanceUnit.Miles));
            toolSubmission.Neighborhood = sorted.First().Neighborhood;

            toolSubmission.CreatedAt = DateTime.UtcNow;

            foreach (var prop in toolSubmission.GetType().GetProperties())
            {
                Console.WriteLine($"{prop.Name}: {prop.GetValue(toolSubmission)}");
            }
            // NEED TO FIX SUBMITTING TOOL TO DB - RN ALL THE FORM DATA IS STORED IN A TOOL OBJECT, SO MAYBE JUST PASS IT TO THE APIS AND CONTROLLERS?
            await ItemService.InsertToolAsync(toolSubmission);

            await LoadUserToolsAsync();

            SubmitOk = true;
            SubmitMessage = "Tool added successfully.";
            toolSubmission = new Tool();
            toolSubmission.OwnerId = OwnerId;
            toolSubmission.OwnerName = OwnerName;
            imageUrlInput = "";
            uploadedImagePreview = null;
        }
        catch (Exception ex)
        {
            SubmitMessage = $"Submit failed: {ex.Message}";
        }
        finally
        {
            var elapsed = DateTime.UtcNow - loadingStartedAt;
            if (elapsed.TotalMilliseconds < 500)
            {
                await Task.Delay(500 - (int)elapsed.TotalMilliseconds);
            }
            IsSubmitting = false;
        }
    }

    private async Task Toggle(Tool item)
    {
        if (Cart.IsInCart(item.Id))
        {
            var cartItem = Cart.Items.First(i => i.DemoItemId == item.Id);
            await Cart.RemoveAsync(cartItem.Id);
        }
        else
        {
            await Cart.AddAsync(item);
        }

        Cart.NotifyChanged();
    }

    private async Task DeleteItem(Tool item)
    {
        if (Cart.IsInCart(item.Id))
        {
            var cartItem = Cart.Items.First(i => i.DemoItemId == item.Id);
            await Cart.RemoveAsync(cartItem.Id);
            Cart.NotifyChanged();
        }

        await ItemService.DeleteToolAsync(item.Id);
        await LoadUserToolsAsync();
    }

    public void Dispose()
    {
        Cart.OnChange -= StateHasChanged;
    }

    private string? ImagePreviewUrl =>
        !string.IsNullOrWhiteSpace(uploadedImagePreview)
            ? uploadedImagePreview
            : (string.IsNullOrWhiteSpace(toolSubmission.ImageUrl) ? null : toolSubmission.ImageUrl);

    private async Task HandleImageFileSelected(InputFileChangeEventArgs e)
    {
        SubmitMessage = "";

        var file = e.File;
        if (file is null)
        {
            return;
        }

        if (!file.ContentType.StartsWith("image/", StringComparison.OrdinalIgnoreCase))
        {
            SubmitOk = false;
            SubmitMessage = "Please choose an image file.";
            return;
        }

        if (file.Size > MaxImageSize)
        {
            SubmitOk = false;
            SubmitMessage = "Image is too large. Max size is 5MB.";
            return;
        }

        await using var stream = file.OpenReadStream(MaxImageSize);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);

        var base64 = Convert.ToBase64String(ms.ToArray());
        var dataUrl = $"data:{file.ContentType};base64,{base64}";

        toolSubmission.ImageUrl = dataUrl;
        uploadedImagePreview = dataUrl;
        imageUrlInput = "";
    }

    private void ApplyImageUrl()
    {
        var url = imageUrlInput?.Trim();
        if (string.IsNullOrWhiteSpace(url))
        {
            return;
        }

        toolSubmission.ImageUrl = url;
        uploadedImagePreview = url;
        SubmitMessage = "";
    }

    private class AccountInfo
    {
        public Guid Id { get; set; }
        public string? Username { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("stripe_account_id")]
        public string? StripeAccountId { get; set; }
    }
}

