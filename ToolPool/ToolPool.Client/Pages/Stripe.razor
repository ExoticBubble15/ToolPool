        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

    .image-drop-input {
        position: absolute;
        inset: 0;
        opacity: 0;
        cursor: pointer;
    }

    .image-drop-content {
        display: flex;
        flex-direction: column;
        gap: 0.15rem;
