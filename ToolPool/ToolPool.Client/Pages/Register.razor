@page "/register"
@rendermode InteractiveServer
@using BlazorBootstrap

<div style="display: flex; flex-direction: column; align-items: center; row-gap: 10px; justify-content: space-between;">
    <input class="form-control" @bind="Username" placeholder="Enter Username" style="width: 300px;" />
    <input class="form-control" @bind="Email" placeholder="Enter Email" style="width: 300px;" />
    <input class="form-control" @bind="Email" placeholder="Confirm Email" style="width: 300px;" />
    <input class="form-control" @bind="PasswordPlain" placeholder="Enter Password" style="width: 300px;" />
    <input class="form-control" @bind="PasswordPlain" placeholder="Confirm Password" style="width: 300px;" />
    <Button style="width: 200px;" Type="ButtonType.Link" Color="ButtonColor.Success" To="/register">Register</Button>
</div>

@code {
    private string Email { get; set; }
    private string Username { get; set; }
    private string PasswordPlain { get; set; }
}
