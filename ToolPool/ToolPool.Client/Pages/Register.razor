@page "/register"
@rendermode InteractiveServer
@using BlazorBootstrap
@using ToolPool.Client.Models
@inject HttpClient Http
@inject NavigationManager Navigation

<div style="display: flex; flex-direction: column; align-items: center; row-gap: 5px; justify-content: space-between;">
    <div class="mb-3"> 
        <input class="form-control @(usernameEmpty ? "is-invalid" : "")" @bind="Username" @bind:event="oninput" placeholder="Enter Username" style="width: 300px;" />
        @if(usernameEmpty)
        {
            <div class="invalid-feedback">
                Username cannot be empty.
            </div>
        }
    </div>
    <div class="mb-3">
        <input class="form-control @(emailEmpty ? "is-invalid" : "")" @bind="Email" @bind:event="oninput" placeholder="Enter Email" style="width: 300px;" />
        @if (emailEmpty)
        {
            <div class="invalid-feedback">
                Email cannot be empty.
            </div>
        }
    </div>
    <div class="mb-3"> 
        <input type="password" class="form-control @(passwordEmpty ? "is-invalid" : "")" @bind="PasswordPlain" @bind:event="oninput" placeholder="Enter Password" style="width: 300px;" />
        @if (passwordEmpty)
        {
            <div class="invalid-feedback">
                Password cannot be empty.
            </div>
        }
    </div>
    <div class="mb-3">
        <input type="password" class="form-control @(passwordMismatch ? "is-invalid" : "")" @bind="PasswordPlainConfirm" @bind:event="oninput" placeholder="Confirm Password" style="width: 300px;" />
        @if (passwordMismatch)
        {
            <div class="invalid-feedback">
                Passwords do not match.
            </div>
        }
        @if (passwordTooShort)
        {
            <div class="invalid-feedback">
                Passwords must be at least 6 characters.
            </div>
        }
    </div>
    
    <Button
        style="width: 200px;"
        Type="ButtonType.Button"
        Color="ButtonColor.Success"
        disabled=@registerLoading
        Loading="@registerLoading"
        @onclick="TryRegister">
        Register
    </Button>
</div>

@code {
    private string? Email { get; set; }
    private string? Username { get; set; }
    private string? PasswordPlain { get; set; }
    private string? PasswordPlainConfirm { get; set; }

    private bool emailEmpty;
    private bool usernameEmpty;
    private bool passwordEmpty;
    private bool passwordMismatch = false;
    private bool failedToRegister = false;
    private bool registerLoading = false;
    private bool passwordTooShort = false;
    public string? registerFailureMessage;
    

    private async Task TryRegister()
    {
        emailEmpty = string.IsNullOrEmpty(Email);
        usernameEmpty = string.IsNullOrEmpty(Username);
        passwordEmpty = string.IsNullOrEmpty(PasswordPlain);
        passwordMismatch = PasswordPlain != PasswordPlainConfirm;
        passwordTooShort = (PasswordPlain?.Length ?? 0) < 6;

        if (emailEmpty || usernameEmpty || passwordEmpty || passwordMismatch || passwordTooShort)
            return;

        var request = new RegisterRequest
        {
            Email = Email!,
            Password = PasswordPlain!,
            Username = Username!
        };
        
        // TODO: Broken?
        registerLoading = true;
        var response = await Http.PostAsJsonAsync("api/users/register", request);
        if (response.IsSuccessStatusCode)
        {
            // redirect or success UI
            registerLoading = false;
            Navigation.NavigateTo("/");
        }
        
    }
}
