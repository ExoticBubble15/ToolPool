@page "/payment/success"
@using System.Text.Json.Serialization
@inject HttpClient Http
@inject NavigationManager Nav

<h3>Processing payment...</h3>

@code {
    [Parameter, SupplyParameterFromQuery]
    public string session_id { get; set; } = "";

    protected override async Task OnInitializedAsync()
    {
        var callbackUrl = Nav.ToAbsoluteUri($"/api/payment/success?session_id={Uri.EscapeDataString(session_id)}");
        var response = await Http.GetAsync(callbackUrl);

        var text = await response.Content.ReadAsStringAsync();

        Console.WriteLine(text);

        if (!response.IsSuccessStatusCode)
        {
            Console.WriteLine("Payment error: " + text);
            return;
        }

        var result = await response.Content.ReadFromJsonAsync<PaymentResult>();

        if (result == null)
        {
            Console.WriteLine("Failed to parse response");
            return;
        }

        string url;
        if (result.InterestId.HasValue)
        {
            url = $"/rental/{result.InterestId.Value}";
            if (!string.IsNullOrEmpty(result.ChannelUrl))
                url += $"?channelUrl={Uri.EscapeDataString(result.ChannelUrl)}";
        }
        else if (!string.IsNullOrEmpty(result.ChannelUrl))
        {
            url = $"/chat/{Uri.EscapeDataString(result.ChannelUrl)}";
        }
        else
        {
            url = "/chat";
        }
        Nav.NavigateTo(url, forceLoad: true);
    }

    class PaymentResult
    {
        [JsonPropertyName("channel_url")]
        public string ChannelUrl { get; set; } = "";

        [JsonPropertyName("interest_id")]
        public Guid? InterestId { get; set; }
    }
}
