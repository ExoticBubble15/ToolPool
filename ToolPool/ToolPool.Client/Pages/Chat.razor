@page "/chat/{ChannelUrl}"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using Microsoft.JSInterop
@using System.Text.Json
@using ToolPool.Client.Models
@using ToolPool.Client.Services
@using Microsoft.AspNetCore.Components
@inject IJSRuntime JS
@inject HttpClient Http
@inject ToolService ToolService
@inject NavigationManager Nav
@implements IAsyncDisposable

<div class="chat-container">
    <div class="chat-header">
        <a href="/chat" class="chat-back">&larr;</a>
        <h2>@ChannelName</h2>
        @* @if (paymentContext?.CanPay == true)
        {
            <button class="chat-pay-btn" @onclick="StartPayment" disabled="@isStartingPayment">
                @(isStartingPayment ? "..." : $"Pay Now: ${paymentContext.TotalAmount:F2}")
            </button>
        } *@
    </div>

    @if (!authChecked)
    {
        <div class="chat-loading">
            <p>Checking login...</p>
        </div>
    }
    else if (currentUser is null)
    {
        <div class="chat-loading">
            <p>Please log in to access chat.</p>
            <a href="/login" style="color: #4CAF50; text-decoration: underline;">Log In</a>
        </div>
    }
    else if (IsLoading)
    {
        <div class="chat-loading">
            <p>Connecting...</p>
        </div>
    }
    else
    {
        <div class="chat-messages" id="chatMessages">
            @foreach (var msg in Messages)
            {
                var isOwn = msg.SenderId == CurrentUserId;
                <div class="chat-bubble @(isOwn ? "own" : "other")">
                    @if (!isOwn)
                    {
                        <span class="chat-sender">@msg.SenderNickname</span>
                    }
                    <p class="chat-text">@msg.Message</p>
                    <span class="chat-time">@FormatTime(msg.CreatedAt)</span>
                </div>
            }
        </div>

        <div class="chat-input-bar">
            <input class="chat-input" placeholder="Type a message..."
                   @bind="MessageText" @bind:event="oninput"
                   @onkeydown="HandleKeyDown" />
            <button class="chat-send" @onclick="SendMessage" disabled="@IsSending">
                @(IsSending ? "..." : "Send")
            </button>
        </div>
    }

    @if (!string.IsNullOrEmpty(Error))
    {
        <div class="chat-error">@Error</div>
    }
</div>

@code {
    [Parameter] public string ChannelUrl { get; set; } = "";

    [SupplyParameterFromQuery(Name = "interestId")]
    public Guid? InterestId { get; set; }

    private AccountInfo? currentUser;
    private bool authChecked = false;
    private List<ChatMessage> Messages = new();
    private string MessageText = "";
    private string CurrentUserId = "";
    private string ChannelName = "Chat";
    private bool IsLoading = true;
    private bool IsSending = false;
    private string Error = "";
    private DotNetObjectReference<Chat>? _dotnetRef;
    private ChatPaymentContext? paymentContext;
    private bool isStartingPayment = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        try
        {
            // Resolve identity from authenticated session
            currentUser = await Http.GetFromJsonAsync<AccountInfo>(Nav.ToAbsoluteUri("/api/profile/me"));
            authChecked = true;

            if (currentUser is null)
            {
                IsLoading = false;
                StateHasChanged();
                return;
            }

            // Use sendbird_user_id for Sendbird connection
            CurrentUserId = currentUser.SendbirdUserId ?? currentUser.Id.ToString();

            var appId = await Http.GetStringAsync("/api/sendbird/app-id");
            appId = appId.Trim('"');

            await JS.InvokeVoidAsync("sendbirdInterop.init", appId);
            await JS.InvokeVoidAsync("sendbirdInterop.connect", CurrentUserId);

            var channelInfo = await JS.InvokeAsync<JsonElement>("sendbirdInterop.getChannel", ChannelUrl);
            ChannelName = channelInfo.GetProperty("name").GetString() ?? "Chat";

            var rawMessages = await JS.InvokeAsync<JsonElement>("sendbirdInterop.loadMessages", ChannelUrl, 50);
            Messages = JsonSerializer.Deserialize<List<ChatMessage>>(rawMessages.GetRawText(),
                new JsonSerializerOptions { PropertyNameCaseInsensitive = true }) ?? new();

            _dotnetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("sendbirdInterop.registerHandler", ChannelUrl, _dotnetRef);

            // Load payment context if interestId is available
            if (InterestId.HasValue)
            {
                paymentContext = await ToolService.GetChatPaymentContextAsync(InterestId.Value);
            }

            IsLoading = false;
            StateHasChanged();
            await ScrollToBottom();
        }
        catch (Exception ex)
        {
            Error = $"Connection failed: {ex.Message}";
            IsLoading = false;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public async Task OnMessageReceived(string json)
    {
        var msg = JsonSerializer.Deserialize<ChatMessage>(json,
            new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
        if (msg is not null)
        {
            Messages.Add(msg);
            await InvokeAsync(StateHasChanged);
            await ScrollToBottom();
        }
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(MessageText) || IsSending) return;

        IsSending = true;
        try
        {
            var result = await JS.InvokeAsync<JsonElement>("sendbirdInterop.sendMessage", ChannelUrl, MessageText.Trim());
            var msg = JsonSerializer.Deserialize<ChatMessage>(result.GetRawText(),
                new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            if (msg is not null)
                Messages.Add(msg);

            MessageText = "";
            StateHasChanged();
            await ScrollToBottom();
        }
        catch (Exception ex)
        {
            Error = $"Send failed: {ex.Message}";
        }
        finally
        {
            IsSending = false;
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
            await SendMessage();
    }

    private async Task ScrollToBottom()
    {
        try
        {
            await JS.InvokeVoidAsync("eval",
                "document.getElementById('chatMessages')?.scrollTo(0, document.getElementById('chatMessages').scrollHeight)");
        }
        catch { }
    }

    private string FormatTime(long timestamp)
    {
        var dt = DateTimeOffset.FromUnixTimeMilliseconds(timestamp).LocalDateTime;
        return dt.ToString("h:mm tt");
    }

    private async Task StartPayment()
    {
        if (isStartingPayment || !InterestId.HasValue) return;
        isStartingPayment = true;

        try
        {
            var checkoutUrl = await ToolService.CheckoutFromChatAsync(InterestId.Value);
            if (!string.IsNullOrEmpty(checkoutUrl))
            {
                Nav.NavigateTo(checkoutUrl, forceLoad: true);
            }
        }
        catch (Exception ex)
        {
            Error = $"Payment failed: {ex.Message}";
        }
        finally
        {
            isStartingPayment = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("sendbirdInterop.disconnect");
        }
        catch { }
        _dotnetRef?.Dispose();
    }

    private class ChatMessage
    {
        public long MessageId { get; set; }
        public string Message { get; set; } = "";
        public string SenderId { get; set; } = "";
        public string SenderNickname { get; set; } = "";
        public long CreatedAt { get; set; }
    }

    private sealed class AccountInfo
    {
        public Guid Id { get; set; }
        public string Username { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;

        [System.Text.Json.Serialization.JsonPropertyName("created_at")]
        public DateTimeOffset? CreatedAt { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("updated_at")]
        public DateTimeOffset? UpdatedAt { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("stripe_account_id")]
        public string? StripeAccountId { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("sendbird_user_id")]
        public string? SendbirdUserId { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("stripe_customer_id")]
        public string? StripeCustomerId { get; set; }

        public DateTimeOffset JoinedAt => CreatedAt?.ToLocalTime() ?? DateTimeOffset.Now;
    }
}
