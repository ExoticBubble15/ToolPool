@page "/express_interest"
@page "/express_interest/{ToolId:guid}"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using BlazorBootstrap
@using ToolPool.Client.Models
@using ToolPool.Client.Services
@using System.Net
@inject ToolService ToolService
@inject NavigationManager Nav
@inject HttpClient Http

@if (!authChecked)
{
    <div class="ei-loading">
        <Spinner />
        <p>Checking login...</p>
    </div>
}
else if (currentUser is null)
{
    <h2 class="pageTitle">Express Interest</h2>
    <div class="ei-empty">
        <p>Please log in to express interest in a tool.</p>
        <button class="ei-browse-btn" @onclick='() => Nav.NavigateTo("/login")'>Log In</button>
    </div>
}
else if (ToolId is null)
{
    <h2 class="pageTitle">Express Interest</h2>
    <span class="pageSubtitle">Select a tool from the Browse page to express interest.</span>
    <div class="ei-empty">
        <p>No tool selected. Browse available tools to get started.</p>
        <button class="ei-browse-btn" @onclick='() => Nav.NavigateTo("/browse")'>Browse Tools</button>
    </div>
}
else if (isLoading)
{
    <div class="ei-loading">
        <Spinner />
        <p>Loading tool details...</p>
    </div>
}
else if (tool is null)
{
    <h2 class="pageTitle">Tool Not Found</h2>
    <div class="ei-empty">
        <p>We couldn't find that tool. It may have been removed.</p>
        <button class="ei-browse-btn" @onclick='() => Nav.NavigateTo("/browse")'>Browse Tools</button>
    </div>
}
else
{
    <div class="ei-back-row">
        <button class="ei-back-btn" @onclick='() => Nav.NavigateTo("/browse")'>← Back to Browse</button>
    </div>

    <div class="ei-layout">
        <div class="ei-left">
            <div class="ei-image" style="background: @GetBgColor(tool.Category)">
                @if (!string.IsNullOrEmpty(tool.ImageUrl))
                {
                    <img src="@tool.ImageUrl" alt="@tool.Name" class="ei-img" />
                }
                <span class="ei-category-tag">@(string.IsNullOrEmpty(tool.Category) ? "General" : tool.Category)</span>
            </div>

            <div class="ei-owner-card">
                <h4 class="ei-owner-title">Listed by</h4>
                <div class="ei-owner-info">
                    <div class="ei-owner-avatar">@(string.IsNullOrEmpty(tool.OwnerName) ? "?" : tool.OwnerName[0].ToString())</div>
                    <div>
                        <span class="ei-owner-name">@(string.IsNullOrEmpty(tool.OwnerName) ? "Owner" : tool.OwnerName)</span>
                    </div>
                </div>
                <div class="ei-owner-location">
                    <span>📍 @(string.IsNullOrEmpty(tool.Neighborhood) ? "Nearby" : tool.Neighborhood)</span>
                </div>
            </div>
        </div>

        <div class="ei-right">
            <h2 class="ei-tool-name">@tool.Name</h2>
            <span class="ei-tool-category">@(string.IsNullOrEmpty(tool.Category) ? "General" : tool.Category)</span>

            <div class="ei-price-row">
                <span class="ei-price">$@tool.Price.ToString("F2")</span>
                <span class="ei-price-unit">/ day</span>
            </div>

            <div class="ei-description">
                <h4>Description</h4>
                <p>@tool.Description</p>
            </div>

            <div class="ei-details-grid">
                <div class="ei-detail-item">
                    <span class="ei-detail-label">Location</span>
                    <span class="ei-detail-value">📍 @(string.IsNullOrEmpty(tool.Neighborhood) ? "Nearby" : tool.Neighborhood)</span>
                </div>
                <div class="ei-detail-item">
                    <span class="ei-detail-label">Category</span>
                    <span class="ei-detail-value">@(string.IsNullOrEmpty(tool.Category) ? "General" : tool.Category)</span>
                </div>
                <div class="ei-detail-item">
                    <span class="ei-detail-label">Owner</span>
                    <span class="ei-detail-value">@(string.IsNullOrEmpty(tool.OwnerName) ? "Owner" : tool.OwnerName)</span>
                </div>
                <div class="ei-detail-item">
                    <span class="ei-detail-label">Availability</span>
                    <span class="ei-detail-value ei-available">Available Now</span>
                </div>
            </div>

            <div class="ei-location-note">
                <span>🔒</span>
                <span>Exact pickup address will be revealed after the owner confirms your booking.</span>
            </div>

            <div class="ei-form">
                <h4>Express Your Interest</h4>

                <div class="ei-form-group">
                    <label class="ei-label">Preferred rental dates</label>
                    <div class="ei-date-row">
                        <input type="date" class="ei-input"
                               @bind="startDate"
                               @bind:after="CheckAvailability" />
                        <span class="ei-date-sep">to</span>
                        <input type="date" class="ei-input"
                               @bind="endDate"
                               @bind:after="CheckAvailability" />
                    </div>
                    @if (hasConflict)
                    {
                        <div class="ei-error">
                            @conflictMessage
                        </div>
                    }
                </div>

                <div class="ei-form-group">
                    <label class="ei-label">Message to owner (optional)</label>
                    <textarea class="ei-textarea" rows="3" placeholder="Hi! I'd like to rent this tool for a weekend project..." @bind="message"></textarea>
                </div>

                @if (!string.IsNullOrEmpty(errorMsg))
                {
                    <div class="ei-error">@errorMsg</div>
                }

                @if (submitted)
                {
                    <div class="ei-success">
                        <span>✔ Interest submitted! A chat channel has been created with the owner.</span>
                    </div>
                    <button class="ei-chat-btn" @onclick="GoToChat">
                        💬 Chat with @(string.IsNullOrEmpty(tool.OwnerName) ? "Owner" : tool.OwnerName)
                    </button>
                }
                else
                {
                    <div class="ei-button-group">
                        <button class="ei-submit-btn" @onclick="ExpressInterestOnly" disabled="@(submitting || !HasValidDates || hasConflict)">
                            @(submitting ? "Submitting..." : "Express Interest & Start Chat")
                        </button>
                        <button class="ei-pay-btn" @onclick="PayAndExpressInterest" disabled="@(submitting || !HasValidDates || hasConflict)">
                            @if (HasValidDates)
                            {
                                <span>Pay Now: $@CalculateTotal().ToString("F2")</span>
                            }
                            else
                            {
                                <span>Pay Now (select dates)</span>
                            }
                        </button>
                    </div>
                    <p class="ei-button-hint">Start a conversation first, or pay now to secure your rental.</p>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid? ToolId { get; set; }

    private Tool? tool;
    private AccountInfo? currentUser;
    private bool authChecked = false;
    private bool isLoading = true;
    private string message = "";
    private DateTime? startDate;
    private DateTime? endDate;
    private bool submitting = false;
    private bool submitted = false;
    private string? errorMsg;
    private string? channelUrl;
    private Guid? interestId;
    private bool hasConflict = false;
    private string? conflictMessage;


    private bool HasValidDates => startDate is not null && endDate is not null && endDate >= startDate;

    private decimal CalculateTotal()
    {
        if (tool is null || startDate is null || endDate is null)
            return 0;
        var days = (endDate.Value - startDate.Value).Days + 1;
        return tool.Price * Math.Max(1, days);
    }
    
    protected override async Task OnInitializedAsync()
    {
        var profileResponse = await Http.GetAsync(Nav.ToAbsoluteUri("/api/profile/me"));
        if (profileResponse.StatusCode == HttpStatusCode.Unauthorized)
        {
            Nav.NavigateTo("/login", forceLoad: true);
            return;
        }

        if (!profileResponse.IsSuccessStatusCode)
        {
            errorMsg = $"Failed to load profile: {(int)profileResponse.StatusCode}";
            authChecked = true;
            isLoading = false;
            return;
        }

        currentUser = await profileResponse.Content.ReadFromJsonAsync<AccountInfo>();
        authChecked = true;

        if (currentUser is null || ToolId is null) { isLoading = false; return; }

        try
        {
            tool = await ToolService.GetToolByIdAsync(ToolId.Value);
        }
        catch
        {
            tool = null;
        }

        isLoading = false;
    }

    private async Task ExpressInterestOnly()
    {
        errorMsg = null;

        if (tool is null || currentUser is null)
            return;

        if (startDate is null || endDate is null)
        {
            errorMsg = "Please select rental dates.";
            return;
        }

        submitting = true;

        try
        {
            var request = new InterestRequest
            {
                ToolId = tool.Id,
                ToolName = tool.Name,
                StartDate = startDate.Value.ToString("yyyy-MM-dd"),
                EndDate = endDate.Value.ToString("yyyy-MM-dd"),
                Message = message,
            };

            var response = await ToolService.SubmitInterestAsync(request);

            if (response.Success && !string.IsNullOrEmpty(response.ChannelUrl))
            {
                channelUrl = response.ChannelUrl;
                interestId = response.InterestId;
                submitted = true;
            }
            else
            {
                errorMsg = "Failed to submit interest. Please try again.";
            }
        }
        catch (Exception ex)
        {
            errorMsg = $"Error: {ex.Message}";
        }
        finally
        {
            submitting = false;
        }
    }

    private async Task PayAndExpressInterest()
    {

        errorMsg = null;

        if (tool is null || currentUser is null)
            return;

        if (startDate is null || endDate is null)
        {
            errorMsg = "Please select rental dates.";
            return;
        }

        submitting = true;

        try
        {

            Console.WriteLine("=== STRIPE DEBUG ===");
            Console.WriteLine("CurrentUser Id: " + currentUser?.Id);
            Console.WriteLine("Is Empty: " + (currentUser?.Id == Guid.Empty));

            var request = new StripeRentalRequest
            {
                ToolId = tool.Id,
                ToolName = tool.Name,
                PricePerDay = tool.Price,
                StartDate = startDate.Value,
                EndDate = endDate.Value,
                UserId = currentUser.Id,
                Message = message,
                UserEmail = currentUser.Email
            };

            Console.WriteLine("REQUEST USER ID (RAW): " + request.UserId);
            Console.WriteLine("REQUEST JSON: " + System.Text.Json.JsonSerializer.Serialize(request));
            var response = await Http.PostAsJsonAsync("api/stripe/checkout-rental", request);
            var result = await response.Content.ReadFromJsonAsync<StripeResponse>();

            if (result?.Url is null)
                throw new Exception("Failed to start Stripe checkout.");
            await Task.Delay(2000);
            Nav.NavigateTo(result.Url, forceLoad: true);
        }
        catch (Exception ex)
        {
            errorMsg = $"Payment failed: {ex.Message}";
        }
        finally
        {
            submitting = false;
        }
    }

    private void GoToChat()
    {
        if (!string.IsNullOrEmpty(channelUrl))
        {
            var url = $"/chat/{channelUrl}";
            if (interestId.HasValue)
                url += $"?interestId={interestId.Value}";
            Nav.NavigateTo(url);
        }
    }

    private async Task CheckAvailability()
    {
        hasConflict = false;
        conflictMessage = null;

        if (tool is null || startDate is null || endDate is null)
            return;

        if (endDate < startDate)
            return;

        try
        {
            var request = new
            {
                ToolId = tool.Id,
                StartDate = startDate.Value.ToString("yyyy-MM-dd"),
                EndDate = endDate.Value.ToString("yyyy-MM-dd")
            };

            var response = await Http.PostAsJsonAsync("api/check-availability", request);
            var result = await response.Content.ReadFromJsonAsync<AvailabilityResponse>();

            hasConflict = result?.HasConflict ?? false;
            conflictMessage = result?.Message;
        }
        catch
        {
            // ignore for UX (or log)
        }
    }
    private static string GetBgColor(string category) => category switch
    {
        "Power Tools" => "#e8e4de",
        "Hand Tools" => "#e0e8df",
        "Equipment" => "#e4dfe8",
        "Garden" => "#dde8dd",
        "Cleaning" => "#dde5e8",
        _ => "#e8e4de"
    };

    private sealed class AccountInfo
    {
        public Guid Id { get; set; }
        public string Username { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;

        [System.Text.Json.Serialization.JsonPropertyName("created_at")]
        public DateTimeOffset? CreatedAt { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("updated_at")]
        public DateTimeOffset? UpdatedAt { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("stripe_account_id")]
        public string? StripeAccountId { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("sendbird_user_id")]
        public string? SendbirdUserId { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("stripe_customer_id")]
        public string? StripeCustomerId { get; set; }

        public DateTimeOffset JoinedAt => CreatedAt?.ToLocalTime() ?? DateTimeOffset.Now;
    }
}
