@using System.Net
@using BlazorBootstrap
@using ToolPool.Client.Services
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using ToolPool.Client.Models
@using ToolPool.Client.Services
@inject NavigationManager Navigation
@inject HttpClient Http
@inject AuthService AuthService
@inject Supabase.Client supabase
@inject ToolService ToolService

<span style="display: flex; align-items: center; gap: 5px">
    @if(authenticated)
    {
        <span style="margin-right: 5px; font-size: 0.9em;">@username</span>
        <Button Class="headerButton" Type="ButtonType.Button" Color="ButtonColor.Success" @onclick='() => Navigation.NavigateTo("/profile")'>Profile</Button>
        <Button Class="headerButton" Type="ButtonType.Button" Color="ButtonColor.Success" @onclick='() => Navigation.NavigateTo("/stripe")'>Listings</Button>
        <Button Class="headerButton" Type="ButtonType.Button" Color="ButtonColor.Success" @onclick='() => Navigation.NavigateTo("/chat")'>Messages</Button>
        <Button Class="headerButton" Type="ButtonType.Button" Color="ButtonColor.Success" @onclick="SignOutAsync">Sign Out</Button>
    } else
    {
        <Button Class="headerButton" Type="ButtonType.Button" Color="ButtonColor.Success" @onclick='() => Navigation.NavigateTo("/login")'>Login</Button>
    }
</span>

@code {
    private bool authenticated;
    private string username = "";
    private bool startup = true;

    protected override async Task OnInitializedAsync()
    {
        Console.WriteLine("Attempting Startup auth session restore");
        try
        {
            var response = await Http.GetAsync("api/auth/status");
            if (response.IsSuccessStatusCode)
            {
                AuthStatus content = await response?.Content?.ReadFromJsonAsync<AuthStatus>() ?? new AuthStatus { authenticated = false };
                authenticated = content.authenticated;
                username = content.email ?? "";
                if (startup)
                {
                    await Http.PostAsync("api/auth/restoreSession", null);
                }
                startup = false;
            }
            else
            {
                authenticated = false;
                startup = true;
            }
        }
        catch
        {
            authenticated = false;
            startup = true;
        }
    }

    protected async Task SignOutAsync()
    {
        var response = await Http.GetAsync("api/auth/logout");
        // log user out of supabase auth
        await supabase.Auth.SignOut();
        if (response.IsSuccessStatusCode)
        {
            // redirect or success UI
            Navigation.NavigateTo("/");
            authenticated = false;
        }
    }
} 
