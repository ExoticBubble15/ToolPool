@using System.Net
@using BlazorBootstrap
@using ToolPool.Client.Services
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using ToolPool.Client.Models
@using ToolPool.Client.Services
@inject NavigationManager Navigation
@inject HttpClient Http
@inject AuthService AuthService
@inject Supabase.Client supabase
@inject ToolService ToolService

<span style="display: flex; align-items: center; gap: 5px">
    @if(authenticated)
    {
        <span style="margin-right: 5px; font-size: 0.9em;">@username</span>
        <Button Class="headerButton" Type="ButtonType.Link" Color="ButtonColor.Success" To="/profile">Profile</Button>
        <Button Class="headerButton" Type="ButtonType.Link" Color="ButtonColor.Success" To="/stripe">Listings</Button>
        <Button Class="headerButton" Type="ButtonType.Link" Color="ButtonColor.Success" To="/chat">Messages</Button>
        <Button Class="headerButton" Type="ButtonType.Button" Color="ButtonColor.Success" @onclick="SignOutAsync">Sign Out</Button>
    } else
    {
        <Button Class="headerButton" Type="ButtonType.Link" Color="ButtonColor.Success" To="/login">Login</Button>
    }
</span>

@code {
    private bool authenticated;
    private string username = "";
    private bool startup = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await Http.GetAsync("api/auth/status");
            if (response.IsSuccessStatusCode)
            {
                authenticated = true;
                AuthStatus content = await response?.Content?.ReadFromJsonAsync<AuthStatus>() ?? new AuthStatus { authenticated = false };
                if (content.authenticated)
                {
                    var result = await Http.GetAsync("api/auth/restoreSession");
                    if (result.IsSuccessStatusCode)
                    {
                        authenticated = true;
                    }
                }
                startup = false;
            }
            else
            {
                authenticated = false;
                startup = true;
            }
        }
        catch
        {
            authenticated = false;
            startup = true;
        }
    }

    protected async Task SignOutAsync()
    {
        var response = await Http.GetAsync("api/auth/logout");
        // log user out of supabase auth
        await supabase.Auth.SignOut();
        if (response.IsSuccessStatusCode)
        {
            // redirect or success UI
            Navigation.NavigateTo("/");
            authenticated = false;
        }
    }
} 
